{
  "title": "event.subEvent.put",
  "type": "array",
  "description": "A list of occurrences of the [event](./models/event.json) when using the `single` or `multiple` [calendarType](./models/event-calendarType.json).",
  "examples": [
    [
      {
        "startDate": "2021-05-17T16:00:00+00:00",
        "endDate": "2021-05-17T22:00:00+00:00",
        "childcare": {
          "start": "08:00",
          "end": "23:00"
        },
        "status": {
          "type": "Available"
        },
        "bookingAvailability": {
          "type": "Available",
          "capacity": 100
        },
        "overnight": true
      }
    ],
    [
      {
        "startDate": "2021-05-17T16:00:00+00:00",
        "endDate": "2021-05-17T22:00:00+00:00",
        "childcare": {
          "start": "08:00",
          "end": "23:00"
        },
        "status": {
          "type": "Available"
        },
        "bookingAvailability": {
          "type": "Available",
          "capacity": 100,
          "remainingCapacity": 60
        }
      },
      {
        "startDate": "2021-05-20T16:00:00+00:00",
        "endDate": "2021-05-20T22:00:00+00:00",
        "status": {
          "type": "Unavailable"
        },
        "bookingAvailability": {
          "type": "Unavailable",
          "capacity": 50,
          "remainingCapacity": 0
        }
      }
    ]
  ],
  "minItems": 1,
  "items": {
    "type": "object",
    "properties": {
      "startDate": {
        "$ref": "./event-startDate.json"
      },
      "endDate": {
        "$ref": "./event-endDate.json"
      },
      "childcare": {
        "$ref": "./event-subEvent-childcare.json"
      },
      "status": {
        "$ref": "./event-status.json"
      },
      "bookingAvailability": {
        "$ref": "./event-bookingAvailability.json"
      },
      "bookingInfo": {
        "$ref": "./event-bookingInfo.json"
      },
      "overnight": {
        "type": "boolean",
        "description": "Indicates whether this occurrence involves an overnight stay. Only accepted when the event has a term with id `0.57.0.0.0` (\"Kamp of vakantie\"). Defaults to `false` when omitted. Automatically reset to `false` when term `0.57.0.0.0` is removed from the event.",
        "example": true
      }
    },
    "required": [
      "startDate",
      "endDate"
    ]
  }
}
